{
  "name": "@repo/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- tsx ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate":  "dotenv -e ../../.env -- tsx ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed":     "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:studio":   "dotenv -e ../../.env -- tsx ./node_modules/drizzle-kit/bin.cjs studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.39.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
